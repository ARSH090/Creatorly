{
  "name": "insta",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "admin:set-custom-claim": "ts-node scripts/set-admin.ts",
    "admin:promote": "ts-node scripts/promote-admin.ts",
    "db:indexes": "tsx src/scripts/createIndexes.ts",
    "verify": "ts-node --project tsconfig.ts-node.json scripts/anti-gravity.ts",
    "verify:ci": "npm run verify && npm run build",
    "test": "jest --config=jest.api.config.js",
    "test:watch": "jest --watch --config=jest.api.config.js",
    "test:coverage": "jest --coverage --config=jest.api.config.js",
    "test:unit": "jest __tests__/unit --config=jest.config.js",
    "test:integration": "jest __tests__/integration --config=jest.api.config.js",
    "test:api-unit": "jest __tests__/api --config=jest.api.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:setup": "playwright test tests/e2e/auth.setup.ts --headed --timeout=60000 --project=setup",
    "test:e2e:debug-auth": "playwright test tests/e2e/auth.debug.ts --headed --timeout=60000 --project=setup",
    "test:e2e:manual-login": "playwright test tests/e2e/auth.manual.ts --headed --timeout=120000 --project=setup",
    "test:e2e:api": "playwright test tests/e2e/08-api-health.spec.ts --project=dashboard",
    "test:e2e:profile": "playwright test tests/e2e/02-profile.spec.ts --project=dashboard",
    "test:e2e:products": "playwright test tests/e2e/03-products.spec.ts --project=dashboard",
    "test:e2e:coupons": "playwright test tests/e2e/04-coupons.spec.ts --project=dashboard",
    "test:e2e:automation": "playwright test tests/e2e/06-automation.spec.ts --project=dashboard",
    "test:e2e:email": "playwright test tests/e2e/07-email-campaigns.spec.ts --project=dashboard",
    "test:e2e:public": "playwright test tests/e2e/09-public-storefront.spec.ts --project=public",
    "test:e2e:report": "node tests/generate-report.js",
    "test:e2e:storefront": "playwright test tests/e2e/05-storefront.spec.ts --project=dashboard",
    "test:e2e:full": "playwright test & node tests/generate-report.js",
    "test:security": "jest __tests__/security --config=jest.api.config.js",
    "test:performance": "jest __tests__/performance --config=jest.api.config.js",
    "test:load": "artillery run load-test.js",
    "test:all": "npm run test && npm run test:e2e:full",
    "test:ci": "npm run test:coverage && npm run test:e2e:full",
    "verify:backup": "ts-node --esm scripts/backup-verification.ts",
    "security:test": "ts-node --esm scripts/run-security-tests.ts",
    "security:audit": "ts-node --esm scripts/security-audit.ts",
    "security:scan": "npm run security:test && npm run security:audit",
    "verify:deployment": "ts-node --esm scripts/verify-deployment.ts",
    "verify:connections": "ts-node --esm scripts/verify-connections.ts",
    "setup:db": "node setup-database.js",
    "test:registration": "node test-registration.js",
    "prelaunch": "npm run build || exit 0 && npm run test || exit 0 && npm run security:scan && npm run verify:connections && npm run verify:frontend",
    "test:selenium": "jest --config=jest.e2e.config.js",
    "worker": "tsx src/workers/main.ts",
    "test:sprite": "testsprite run",
    "test:sprite:headed": "testsprite run --headed",
    "test:sprite:ui": "testsprite run --ui",
    "test:sprite:auth": "testsprite run testsprite/01-auth.test.ts",
    "test:sprite:profile": "testsprite run testsprite/02-profile.test.ts",
    "test:sprite:products": "testsprite run testsprite/03-products.test.ts",
    "test:sprite:coupons": "testsprite run testsprite/04-coupons.test.ts",
    "test:sprite:store": "testsprite run testsprite/05-storefront.test.ts",
    "test:sprite:autodm": "testsprite run testsprite/06-autodm.test.ts",
    "test:sprite:email": "testsprite run testsprite/07-email.test.ts",
    "test:sprite:payments": "testsprite run testsprite/08-payments.test.ts",
    "test:sprite:security": "testsprite run testsprite/10-security.test.ts",
    "test:sprite:journey": "testsprite run testsprite/11-user-journey.test.ts",
    "test:sprite:api": "testsprite run testsprite/12-api-health.test.ts",
    "test:sprite:full": "testsprite run --reporter=html"
  },
